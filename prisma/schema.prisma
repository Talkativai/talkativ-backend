generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String?
  firstName        String
  lastName         String
  role             Role           @default(OWNER)
  status           UserStatus     @default(ACTIVE)
  twoFactorEnabled Boolean        @default(false)
  twoFactorSecret  String?
  emailVerified    Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  googleId         String?
  business         Business?
  otpTokens        OtpToken[]
  refreshTokens    RefreshToken[]
  sessions         Session[]

  @@index([googleId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  device     String
  location   String
  ip         String
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id                String                @id @default(uuid())
  userId            String                @unique
  name              String
  type              String
  address           String
  phone             String
  email             String?
  website           String?
  primaryLanguage   String                @default("en")
  timezone          String                @default("Europe/London")
  openingHours      Json?
  onboardingStep    Int                   @default(0)
  onboardingDone    Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  country           String                @default("")
  currency          String                @default("GBP")
  postalCode        String?
  lat               Float?
  lng               Float?
  agent             Agent?
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  extractions       BusinessExtraction[]
  calls             Call[]
  faqs              Faq[]
  integrations      Integration[]
  menuCategories    MenuCategory[]
  notifSettings     NotificationSettings?
  orders            Order[]
  orderingPolicy    OrderingPolicy?
  phoneConfig       PhoneConfig?
  reservations      Reservation[]
  reservationPolicy ReservationPolicy?
  staff             Staff[]
  subscription      Subscription?
}

model Staff {
  id           String    @id @default(uuid())
  businessId   String
  username     String
  passwordHash String
  firstName    String
  lastName     String
  role         StaffRole @default(STAFF)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  email        String?
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, username])
}

model Agent {
  id                String   @id @default(uuid())
  businessId        String   @unique
  elevenlabsAgentId String?
  name              String   @default("Aria")
  voiceId           String   @default("21m00Tcm4TlvDq8ikWAM")
  voiceName         String   @default("Aria")
  voiceDescription  String   @default("Warm & professional")
  openingGreeting   String   @default("Thanks for calling! How can I help you today?")
  closingMessage    String?
  systemPrompt      String?
  transferNumber    String?
  transferEnabled   Boolean  @default(true)
  takeMessages      Boolean  @default(true)
  acceptOrders      Boolean  @default(true)
  takeReservations  Boolean  @default(true)
  answerAfterHours  Boolean  @default(false)
  aiPhoneNumber     String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agentSchedule     Json?
  gender            String   @default("female")
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model PhoneConfig {
  id                String   @id @default(uuid())
  businessId        String   @unique
  forwardNumber     String?
  ringsBeforeAi     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  callRecording     Boolean  @default(true)
  voicemailFallback Boolean  @default(false)
  assignedNumber    String?
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id                    String   @id @default(uuid())
  businessId            String   @unique
  emailNewOrder         Boolean  @default(true)
  emailMissedCall       Boolean  @default(true)
  emailDailySummary     Boolean  @default(true)
  pushLiveCall          Boolean  @default(true)
  pushNewOrder          Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  emailAgentOffline     Boolean  @default(true)
  emailNewReservation   Boolean  @default(true)
  emailPaymentProcessed Boolean  @default(true)
  emailRefundRequest    Boolean  @default(true)
  emailWeeklyReport     Boolean  @default(true)
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model OrderingPolicy {
  id                    String   @id @default(uuid())
  businessId            String   @unique
  deliveryEnabled       Boolean  @default(false)
  collectionEnabled     Boolean  @default(false)
  deliveryRadius        Float    @default(5.0)
  deliveryRadiusUnit    String   @default("miles")
  minOrderAmount        Float    @default(0)
  payNowEnabled         Boolean  @default(true)
  payOnDelivery         Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  collectionPayNow      Boolean  @default(false)
  collectionPayOnPickup Boolean  @default(false)
  deliveryFee           Float    @default(0)
  deliveryPayNow        Boolean  @default(false)
  deliveryPayOnDelivery Boolean  @default(false)
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ReservationPolicy {
  id                    String      @id @default(uuid())
  businessId            String      @unique
  reservationsEnabled   Boolean     @default(false)
  depositRequired       Boolean     @default(false)
  depositAmount         Float       @default(0)
  depositType           DepositType @default(PER_GUEST)
  maxPartySize          Int         @default(20)
  seatingCapacity       Int         @default(50)
  bookingLeadTime       Int         @default(24)
  cancellationHours     Int         @default(24)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  refundPercentage      Int         @default(100)
  business              Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Call {
  id               String       @id @default(uuid())
  businessId       String
  callerName       String?
  callerPhone      String?
  status           CallStatus   @default(RINGING)
  outcome          String?
  outcomeType      OutcomeType?
  duration         Int?
  amount           Decimal?
  transcript       String?
  recordingUrl     String?
  elevenlabsConvId String?
  startedAt        DateTime     @default(now())
  endedAt          DateTime?
  createdAt        DateTime     @default(now())
  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order            Order?
  reservation      Reservation?

  @@index([businessId])
  @@index([status])
}

model Order {
  id              String      @id @default(uuid())
  businessId      String
  callId          String?     @unique
  customerName    String
  items           String
  itemsJson       Json?
  type            OrderType   @default(DELIVERY)
  status          OrderStatus @default(PENDING)
  amount          Decimal
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  allergies       String?
  customerEmail   String?
  customerPhone   String?
  paymentIntentId String?
  paymentMethod   String?     @default("pay_on_delivery")
  paymentStatus   String?     @default("pending")
  deliveryAddress String?
  posOrderId      String?
  paymentLinkUrl  String?
  paymentProvider String?
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  call            Call?       @relation(fields: [callId], references: [id])

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
}

model Reservation {
  id                     String            @id @default(uuid())
  businessId             String
  callId                 String?           @unique
  guestName              String
  guestPhone             String?
  guests                 Int
  dateTime               DateTime
  status                 ReservationStatus @default(PENDING)
  note                   String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  depositAmount          Decimal?          @default(0)
  depositPaid            Boolean           @default(false)
  depositPaymentIntentId String?
  depositRequired        Boolean           @default(false)
  guestEmail             String?
  externalId             String?
  talkativRef            String?           @unique
  reminderSent           Boolean           @default(false)
  business               Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  call                   Call?             @relation(fields: [callId], references: [id])

  @@index([businessId])
  @@index([status])
  @@index([dateTime])
}

model MenuCategory {
  id         String     @id @default(uuid())
  businessId String
  name       String
  sortOrder  Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@index([businessId])
}

model MenuItem {
  id          String         @id @default(uuid())
  categoryId  String
  name        String
  description String?
  price       Decimal
  status      MenuItemStatus @default(ACTIVE)
  source      String?        // null = manual/DB, "Square"/"Clover"/"Zettle" = cached from POS
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  category    MenuCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([status])
}

model Integration {
  id         String            @id @default(uuid())
  businessId String
  name       String
  category   String
  status     IntegrationStatus @default(AVAILABLE)
  config     Json?
  lastSynced DateTime?
  isPrimary  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
}

model Subscription {
  id                   String             @id @default(uuid())
  businessId           String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeScheduleId     String?
  plan                 PlanType           @default(GROWTH)
  pendingPlan          PlanType?
  pendingPlanDate      DateTime?
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  cardBrand            String?
  cardLast4            String?
  callsThisMonth       Int                @default(0)
  callsResetAt         DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  invoices             Invoice[]
  business             Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String       @id @default(uuid())
  subscriptionId  String
  stripeInvoiceId String?
  amount          Decimal
  status          String
  paidAt          DateTime?
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime     @default(now())
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model BusinessExtraction {
  id             String   @id @default(uuid())
  businessId     String
  source         String
  sourceRef      String?
  category       String
  rawText        String?
  structuredData Json?
  createdAt      DateTime @default(now())
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Faq {
  id         String   @id @default(uuid())
  businessId String
  question   String
  answer     String
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  MANAGER
  STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum StaffRole {
  MANAGER
  STAFF
}

enum DepositType {
  PER_GUEST
  PER_TABLE
  FIXED
}

enum CallStatus {
  RINGING
  LIVE
  COMPLETED
  MISSED
}

enum OutcomeType {
  ORDER
  ENQUIRY
  MISSED
  RESERVATION
}

enum OrderType {
  DELIVERY
  COLLECTION
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum MenuItemStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum IntegrationStatus {
  AVAILABLE
  CONNECTED
  ERROR
}

enum PlanType {
  GROWTH
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}
